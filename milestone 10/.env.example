# .env.example
# ─────────────
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to Git — it is listed in .gitignore.

# ── Required ─────────────────────────────────────────────────────────────────

# Groq API key — get one free at https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Optional (only needed if using --push flag) ───────────────────────────────

# GitHub Personal Access Token (classic) — needs 'repo' scope
# Create at https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
